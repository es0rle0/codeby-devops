# ---------------------------
# Vagrant / VirtualBox
# ---------------------------
**/.vagrant/
*.box

# ---------------------------
# Terraform
# ---------------------------
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/crash.log

# ---------------------------
# Ansible: retry files, caches
# ---------------------------
*.retry
**/.ansible/
**/facts.d/
**/*.log

# Allow Lesson17 script log (task requirement)
!lesson17/script.log

# ---------------------------
# Lesson18 runtime data (do not commit)
# ---------------------------
lesson18/data/
lesson18/.env

# ---------------------------
# SSH keys / sensitive files
# ---------------------------
**/*.pem
**/*.key
**/*_key
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub
**/authorized_keys
**/known_hosts
**/ssh_config
**/.ssh/

# Allow non-sensitive public certs if you ever commit them
!**/*.crt

# ---------------------------
# OS / Editor / temp files
# ---------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
*~
*.bak

# ---------------------------
# Python (если вдруг где-то появится)
# ---------------------------
__pycache__/
*.pyc
.venv/
venv/

# Vagrant keys accidentally copied
lesson12/vagrant/vagrant.key.*
lesson12/vagrant/*.key

# Vagrant keys accidentally copied
lesson12/vagrant/vagrant.key.*
lesson12/vagrant/*.key

# Terraform
**/.terraform/
**/*.tfstate
**/*.tfstate.*
# Lesson20 local secrets (do not commit)
lesson20/manifests/01-secret-wp.yaml
values.private.yaml
origin/main
